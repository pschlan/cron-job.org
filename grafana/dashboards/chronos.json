        "showPercentChange": false,
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "expr": "clamp_min(sum(rate(chronos_jobs_executed_total{instance=~\"$instance\"}[$__rate_interval])) - sum(rate(chronos_update_results_total{instance=~\"$instance\"}[$__rate_interval])), 0)",
          "legendFormat": "executed − persisted",
          "refId": "A"
